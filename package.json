{
  "name": "tripboard",
  "private": true,
  "version": "0.1.0",
  "description": "Collaborative family trip-planning app (places, meals, voting, scheduling, expenses).",
  "workspaces": [
    "packages/shared",
    "services/api",
    "apps/web"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run typecheck",
    "seed": "node --import tsx scripts/seed.ts",
    "dev": "npm run dev --workspace apps/web"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
