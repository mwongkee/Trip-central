# Copy to .env.local for local dev. All optional.

# Backend selection:
#   unset            → local in-browser demo store (default in dev)
#   local            → force the local demo store
#   /api             → same-origin API (what production uses)
#   https://…/api    → a specific deployed API
# VITE_API_BASE=local

# Full MapLibre style URL. Without it the map shows an accessible list fallback.
# With Amazon Location you build this from VITE_MAP_NAME + region and sign tile
# requests with Identity-Pool creds (see PLAN.md M1/M5).
# VITE_MAP_STYLE=

# Amazon Location / Cognito (used by the deploy workflow; see docs/cicd.md)
# VITE_AWS_REGION=ca-central-1
# VITE_MAP_NAME=tripboard-map
# VITE_PLACE_INDEX=tripboard-places
# VITE_COGNITO_USER_POOL_ID=
# VITE_COGNITO_CLIENT_ID=
# VITE_IDENTITY_POOL_ID=
